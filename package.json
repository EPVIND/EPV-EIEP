{
  "name": "eiep-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EPV Industrial Enterprise Platform controlled implementation workspace",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "boundary:check": "node scripts/check-production-boundary.mjs",
    "secrets:check": "node scripts/check-secrets.mjs",
    "traceability:check": "node scripts/check-traceability.mjs",
    "database:verify": "node scripts/verify-postgres-foundation.mjs",
    "database:bootstrap-azure": "pnpm --filter @eiep/database bootstrap:azure-identities",
    "database:bootstrap-application-identities": "pnpm --filter @eiep/api bootstrap:application-identities",
    "pilot:manifest": "node scripts/create-local-pilot-manifest.mjs",
    "pilot:run": "node scripts/local-pilot-runtime.mjs run",
    "pilot:status": "node scripts/local-pilot-runtime.mjs status",
    "pilot:stop": "node scripts/local-pilot-runtime.mjs stop",
    "infrastructure:verify": "node scripts/verify-infrastructure.mjs",
    "route-schemas:generate": "tsx --conditions=development scripts/generate-route-schemas.ts",
    "route-schemas:verify": "tsx --conditions=development scripts/generate-route-schemas.ts --check",
    "openapi:generate": "pnpm run route-schemas:generate && tsx --conditions=development scripts/generate-openapi.ts",
    "openapi:verify": "pnpm run route-schemas:verify && tsx --conditions=development scripts/generate-openapi.ts --check",
    "sbom:generate": "node scripts/generate-sbom.mjs",
    "build": "pnpm -r --if-present build",
    "runtime:verify": "pnpm run build && node scripts/verify-runtime-artifacts.mjs",
    "containers:verify": "node scripts/verify-container-definitions.mjs",
    "containers:build": "node scripts/build-containers.mjs",
    "typecheck": "pnpm -r --if-present typecheck && tsc -p tsconfig.tests.json --noEmit",
    "test": "tsx --conditions=development --test tests/unit/*.test.ts tests/integration/*.test.ts tests/security/*.test.ts tests/acceptance/*.test.ts",
    "test:browser": "playwright test",
    "verify": "pnpm run boundary:check && pnpm run secrets:check && pnpm run traceability:check && pnpm run infrastructure:verify && pnpm run containers:verify && pnpm run openapi:verify && pnpm run typecheck && pnpm run test && pnpm run runtime:verify",
    "dev:api": "pnpm --filter @eiep/api dev",
    "dev:web": "pnpm --filter @eiep/web dev",
    "dev:portal": "pnpm --filter @eiep/portal dev"
  },
  "devDependencies": {
    "@eiep/api": "workspace:*",
    "@eiep/document-processing": "workspace:*",
    "@eiep/integration": "workspace:*",
    "@eiep/job-worker": "workspace:*",
    "@eiep/recovery": "workspace:*",
    "@eiep/rules-engine": "workspace:*",
    "@eiep/shared-types": "workspace:*",
    "@eiep/turnover-renderer": "workspace:*",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^24.0.0",
    "embedded-postgres": "18.4.0-beta.17",
    "jose": "^6.0.0",
    "pdf-lib": "1.17.1",
    "tsx": "^4.0.0",
    "typescript": "~5.9.0"
  }
}
