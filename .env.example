# Non-secret local defaults only. Copy to .env and supply secrets outside source control.
EIEP_ENV=development
AUTH_MODE=development
DATA_STORE=memory
HOST=127.0.0.1
PORT=3100
RATE_LIMIT_MAX=300
# Required in production; inject from protected configuration and rotate it.
METRICS_TOKEN=<at-least-32-random-characters>

# Required when AUTH_MODE=oidc. Do not place client secrets in this file.
OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_AUDIENCE=<api-application-id>

# Required when DATA_STORE=postgres. Use protected configuration in hosted environments.
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/eiep_development
DATABASE_RUNTIME_ROLE=eiep_runtime

# Local development uses this private filesystem root. Production uses the managed settings below.
FILE_STORAGE_ROOT=.eiep-file-storage
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3200,http://127.0.0.1:3201

# Required in production. The API identity is scoped only to the private staged container;
# the separately deployed worker identity uses the same variable names with account-level data scope.
AZURE_STORAGE_ACCOUNT_NAME=<private-storage-account>
AZURE_CLIENT_ID=<user-assigned-managed-identity-client-id>

# Job-worker-only settings. Its DATABASE_RUNTIME_ROLE must be eiep_job_worker.
WORKER_USER_ID=<governed-service-account-id>
WORKER_ORGANIZATION_ID=<business-scope-organization-id>
CLAMAV_HOST=<private-scanner-host>
CLAMAV_PORT=3310
